# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# raw video / unsupported formats in public/images — not used by the site
# (lib/gallery.ts only reads jpg/jpeg/png/gif/webp/avif); one file here is
# 203MB, over GitHub's 100MB hard limit, so these must stay untracked.
public/images/**/*.mov
public/images/**/*.MOV
public/images/**/*.mp4
public/images/**/*.MP4
public/images/**/*.heic
public/images/**/*.HEIC
public/images/**/*.heif
public/images/**/*.HEIF
public/images/**/*.tiff
public/images/**/*.TIFF
